  void _showShariaQADialog(BuildContext context, String title, String url, LanguageService lang) {
    String instructionsText;
    String openBtn;
    String copyBtn;
    String copiedText;
    
    switch (lang.currentLanguage) {
      case AppLanguage.arabic:
        instructionsText = 'هذا الموقع باللغة الكردية.\n\n'
            '١. أولاً اذهب إلى إعدادات الموقع وغيّر اللغة إلى العربية.\n'
            '٢. يجب إنشاء حساب أولاً.\n'
            '٣. بعد ذلك يمكنك طرح الأسئلة الشرعية.';
        openBtn = 'فتح في المتصفح';
        copyBtn = 'نسخ الرابط';
        copiedText = 'تم النسخ';
        break;
      case AppLanguage.kurdish:
        instructionsText = 'ئەم وێبسایتە بە زمانی کوردییە.\n\n'
            '١. سەرەتا بڕۆنە سیتینگی وێبسایتەکە و زمانەکەی بکەن بە عەرەبی.\n'
            '٢. پێویستە سەرەتا ئەکاونتێک دروست بکەن.\n'
            '٣. پاشان پرسیاری شەرعی لێ بکەن.';
        openBtn = 'کردنەوە لە براوسەر';
        copyBtn = 'کۆپیکردنی لینک';
        copiedText = 'کۆپی کرا';
        break;
      case AppLanguage.english:
        instructionsText = 'This website is in Kurdish.\n\n'
            '1. First go to the website settings and change the language to Arabic.\n'
            '2. You need to create an account first.\n'
            '3. Then you can ask Sharia questions.';
        openBtn = 'Open in Browser';
        copyBtn = 'Copy Link';
        copiedText = 'Copied';
        break;
    }
  
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (context) {
        bool isCopied = false;
        
        return StatefulBuilder(
          builder: (context, setState) => Container(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                begin: Alignment.topLeft,
                end: Alignment.bottomRight,
                colors: lang.isDarkMode 
                  ? [const Color(0xFF1a2a4a), const Color(0xFF0D1624)] 
                  : [Colors.white, const Color(0xFFF8F9FA)],
              ),
              borderRadius: const BorderRadius.vertical(top: Radius.circular(32)),
              boxShadow: [
                BoxShadow(
                  color: Colors.black.withOpacity(0.25),
                  blurRadius: 30,
                  offset: const Offset(0, -10),
                ),
              ],
            ),
            padding: const EdgeInsets.fromLTRB(28, 16, 28, 40),
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                // Handle
                Center(
                  child: Container(
                    width: 50, 
                    height: 5, 
                    margin: const EdgeInsets.only(bottom: 24),
                    decoration: BoxDecoration(
                      color: lang.isDarkMode ? Colors.white24 : Colors.grey[300], 
                      borderRadius: BorderRadius.circular(10),
                    )
                  ),
                ),
                
                // Icon with Glow
                Container(
                  padding: const EdgeInsets.all(20),
                  decoration: BoxDecoration(
                    gradient: const LinearGradient(
                      colors: [Color(0xFF66BB6A), Color(0xFF43A047)],
                      begin: Alignment.topLeft,
                      end: Alignment.bottomRight,
                    ),
                    shape: BoxShape.circle,
                    boxShadow: [
                      BoxShadow(
                        color: const Color(0xFF388E3C).withOpacity(0.4),
                        blurRadius: 20,
                        offset: const Offset(0, 10),
                      ),
                    ],
                  ),
                  child: const Icon(Icons.question_answer_rounded, size: 36, color: Colors.white),
                ),
                const SizedBox(height: 20),
                
                Text(
                  title, 
                  style: lang.getTextStyle(
                    fontSize: 24, 
                    fontWeight: FontWeight.bold, 
                    color: lang.isDarkMode ? Colors.white : Colors.black87
                  ),
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: 16),
                
                // Instructions box
                Container(
                  width: double.infinity,
                  padding: const EdgeInsets.all(16),
                  decoration: BoxDecoration(
                    color: lang.isDarkMode ? const Color(0xFF2E7D32).withOpacity(0.15) : const Color(0xFFE8F5E9),
                    borderRadius: BorderRadius.circular(16),
                    border: Border.all(
                      color: lang.isDarkMode ? const Color(0xFF66BB6A).withOpacity(0.3) : const Color(0xFF81C784).withOpacity(0.5),
                    ),
                  ),
                  child: Text(
                    instructionsText,
                    style: lang.getTextStyle(
                      fontSize: 14,
                      color: lang.isDarkMode ? Colors.white70 : Colors.black87,
                      height: 1.7,
                    ),
                    textAlign: lang.isRTL ? TextAlign.right : TextAlign.left,
                  ),
                ),
                const SizedBox(height: 24),
                
                // Link Box
                Container(
                  padding: const EdgeInsets.all(6),
                  decoration: BoxDecoration(
                    color: lang.isDarkMode ? Colors.white.withOpacity(0.05) : Colors.grey[100],
                    borderRadius: BorderRadius.circular(20),
                    border: Border.all(color: lang.isDarkMode ? Colors.white10 : Colors.grey[300]!),
                  ),
                  child: Row(
                    children: [
                      Expanded(
                        child: Container(
                          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
                          child: Text(
                            url,
                            style: TextStyle(
                              fontFamily: 'Courier', 
                              fontSize: 14, 
                              color: lang.isDarkMode ? Colors.white70 : Colors.black87,
                              fontWeight: FontWeight.w500,
                            ),
                            overflow: TextOverflow.ellipsis,
                          ),
                        ),
                      ),
                      Material(
                        color: Colors.transparent,
                        child: InkWell(
                          onTap: () {
                            Clipboard.setData(ClipboardData(text: url));
                            setState(() {
                              isCopied = true;
                            });
                            Future.delayed(const Duration(seconds: 2), () {
                              if (context.mounted) {
                                setState(() {
                                  isCopied = false;
                                });
                              }
                            });
                          },
                          borderRadius: BorderRadius.circular(16),
                          child: AnimatedContainer(
                            duration: const Duration(milliseconds: 300),
                            padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
                            decoration: BoxDecoration(
                              color: isCopied 
                                  ? const Color(0xFF4CAF50).withOpacity(0.15) 
                                  : const Color(0xFF388E3C).withOpacity(0.15),
                              borderRadius: BorderRadius.circular(16),
                              border: Border.all(
                                color: isCopied ? const Color(0xFF4CAF50) : Colors.transparent, 
                                width: 1
                              ),
                            ),
                            child: Row(
                              mainAxisSize: MainAxisSize.min,
                              children: [
                                Icon(
                                  isCopied ? Icons.check_circle_rounded : Icons.copy_rounded, 
                                  size: 22, 
                                  color: isCopied ? const Color(0xFF4CAF50) : const Color(0xFF388E3C)
                                ),
                                if (isCopied) ...[
                                  const SizedBox(width: 8),
                                  Text(
                                    copiedText,
                                    style: lang.getTextStyle(
                                      fontSize: 14,
                                      fontWeight: FontWeight.bold,
                                      color: const Color(0xFF4CAF50),
                                    ),
                                  ),
                                ]
                              ],
                            ),
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
                const SizedBox(height: 24),
                
                // Open Button
                SizedBox(
                  width: double.infinity,
                  child: Container(
                    decoration: BoxDecoration(
                      gradient: const LinearGradient(
                        colors: [Color(0xFF66BB6A), Color(0xFF388E3C)],
                      ),
                      borderRadius: BorderRadius.circular(20),
                      boxShadow: [
                        BoxShadow(
                          color: const Color(0xFF388E3C).withOpacity(0.3),
                          blurRadius: 15,
                          offset: const Offset(0, 8),
                        ),
                      ],
                    ),
                    child: ElevatedButton(
                      onPressed: () {
                         Navigator.pop(context);
                         _launchExternalUrl(url);
                      },
                      style: ElevatedButton.styleFrom(
                        backgroundColor: Colors.transparent,
                        foregroundColor: Colors.white,
                        padding: const EdgeInsets.symmetric(vertical: 20),
                        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
                        elevation: 0,
                        shadowColor: Colors.transparent,
                      ),
                      child: Row(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          const Icon(Icons.open_in_browser_rounded, size: 24),
                          const SizedBox(width: 12),
                          Text(
                            openBtn,
                            style: lang.getTextStyle(
                              fontSize: 18,
                              fontWeight: FontWeight.bold,
                              color: Colors.white,
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ],
            ),
          ),
        );
      },
    );
  }

