  void _showExternalLinkDialog(BuildContext context, String title, String url, LanguageService lang) {
    String msg;
    String openBtn;
    String copyBtn;
    String copiedText;
    String titleText;
    
    switch (lang.currentLanguage) {
      case AppLanguage.arabic:
        titleText = 'فتح الرابط';
        msg = 'يرجى فتح الرابط في المتصفح (سافاري في الآيفون أو كروم في الأندرويد).\n\n'
            '١. يجب إنشاء حساب أولاً.\n'
            '٢. بعد ذلك يمكنك توجيه أسئلتك.';
        openBtn = 'فتح في المتصفح';
        copyBtn = 'نسخ الرابط';
        copiedText = 'تم النسخ';
        break;
      case AppLanguage.kurdish:
        titleText = 'کردنەوەی لینک';
        msg = 'تکایە لینکەکە لە براوسەر بکەوە (لە ئایفۆن سافاری و لە ئەندرۆید کرۆم).\n\n'
            '١. پێویستە سەرەتا ئەکاونتێک دروست بکەیت.\n'
            '٢. پاشان پرسیارەکانت ئاراستە بکە.';
        openBtn = 'کردنەوە لە براوسەر';
        copyBtn = 'کۆپیکردنی لینک';
        copiedText = 'کۆپی کرا';
        break;
      case AppLanguage.english:
        titleText = 'Open Link';
        msg = 'Please open the link in your browser (Safari on iPhone or Chrome on Android).\n\n'
            '1. You need to create an account first.\n'
            '2. Then you can ask your questions.';
        openBtn = 'Open in Browser';
        copyBtn = 'Copy Link';
        copiedText = 'Copied';
        break;
    }
  
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (context) {
        bool isCopied = false;
        
        return StatefulBuilder(
          builder: (context, setState) => Container(
            decoration: BoxDecoration(
              // Premium Gradient Background
              gradient: LinearGradient(
                begin: Alignment.topLeft,
                end: Alignment.bottomRight,
                colors: lang.isDarkMode 
                  ? [const Color(0xFF1a2a4a), const Color(0xFF0D1624)] 
                  : [Colors.white, const Color(0xFFF8F9FA)],
              ),
              borderRadius: const BorderRadius.vertical(top: Radius.circular(32)),
              boxShadow: [
                BoxShadow(
                  color: Colors.black.withOpacity(0.25),
                  blurRadius: 30,
                  offset: const Offset(0, -10),
                ),
              ],
            ),
            padding: const EdgeInsets.fromLTRB(28, 16, 28, 40),
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                // Handle
                Center(
                  child: Container(
                    width: 50, 
                    height: 5, 
                    margin: const EdgeInsets.only(bottom: 24),
                    decoration: BoxDecoration(
                      color: lang.isDarkMode ? Colors.white24 : Colors.grey[300], 
                      borderRadius: BorderRadius.circular(10),
                    )
                  ),
                ),
                
                // Icon with Glow
                Container(
                  padding: const EdgeInsets.all(20),
                  decoration: BoxDecoration(
                    gradient: const LinearGradient(
                      colors: [Color(0xFF2196F3), Color(0xFF64B5F6)],
                      begin: Alignment.topLeft,
                      end: Alignment.bottomRight,
                    ),
                    shape: BoxShape.circle,
                    boxShadow: [
                      BoxShadow(
                        color: const Color(0xFF2196F3).withOpacity(0.4),
                        blurRadius: 20,
                        offset: const Offset(0, 10),
                      ),
                    ],
                  ),
                  child: const Icon(Icons.public, size: 36, color: Colors.white),
                ),
                const SizedBox(height: 20),
                
                Text(
                  title, 
                  style: lang.getTextStyle(
                    fontSize: 24, 
                    fontWeight: FontWeight.bold, 
                    color: lang.isDarkMode ? Colors.white : Colors.black87
                  ),
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: 12),
                
                Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 12),
                  child: Text(
                    msg, 
                    textAlign: TextAlign.center, 
                    style: lang.getTextStyle(
                      fontSize: 16, 
                      color: lang.isDarkMode ? Colors.white70 : Colors.black54,
                      height: 1.6,
                    ),
                  ),
                ),
                const SizedBox(height: 32),
                
                // Link Box - Modern Glass Effect
                Container(
                  padding: const EdgeInsets.all(6),
                  decoration: BoxDecoration(
                    color: lang.isDarkMode ? Colors.white.withOpacity(0.05) : Colors.grey[100],
                    borderRadius: BorderRadius.circular(20),
                    border: Border.all(color: lang.isDarkMode ? Colors.white10 : Colors.grey[300]!),
                  ),
                  child: Row(
                    children: [
                      Expanded(
                        child: Container(
                          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
                          child: Text(
                            url,
                            style: TextStyle(
                              fontFamily: 'Courier', 
                              fontSize: 14, 
                              color: lang.isDarkMode ? Colors.white70 : Colors.black87,
                              fontWeight: FontWeight.w500,
                            ),
                            overflow: TextOverflow.ellipsis,
                          ),
                        ),
                      ),
                      Material(
                        color: Colors.transparent,
                        child: InkWell(
                          onTap: () {
                            Clipboard.setData(ClipboardData(text: url));
                            setState(() {
                              isCopied = true;
                            });
                            Future.delayed(const Duration(seconds: 2), () {
                              if (context.mounted) {
                                setState(() {
                                  isCopied = false;
                                });
                              }
                            });
                          },
                          borderRadius: BorderRadius.circular(16),
                          child: AnimatedContainer(
                            duration: const Duration(milliseconds: 300),
                            padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
                            decoration: BoxDecoration(
                              color: isCopied 
                                  ? const Color(0xFF4CAF50).withOpacity(0.15) 
                                  : const Color(0xFF2196F3).withOpacity(0.15),
                              borderRadius: BorderRadius.circular(16),
                              border: Border.all(
                                color: isCopied ? const Color(0xFF4CAF50) : Colors.transparent, 
                                width: 1
                              ),
                            ),
                            child: Row(
                              mainAxisSize: MainAxisSize.min,
                              children: [
                                Icon(
                                  isCopied ? Icons.check_circle_rounded : Icons.copy_rounded, 
                                  size: 22, 
                                  color: isCopied ? const Color(0xFF4CAF50) : const Color(0xFF2196F3)
                                ),
                                if (isCopied) ...[
                                  const SizedBox(width: 8),
                                  Text(
                                    copiedText,
                                    style: lang.getTextStyle(
                                      fontSize: 14,
                                      fontWeight: FontWeight.bold,
                                      color: const Color(0xFF4CAF50),
                                    ),
                                  ),
                                ]
                              ],
                            ),
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
                const SizedBox(height: 24),
                
                // Open Button - Gradient
                SizedBox(
                  width: double.infinity,
                  child: Container(
                    decoration: BoxDecoration(
                      gradient: const LinearGradient(
                        colors: [Color(0xFF2196F3), Color(0xFF1976D2)],
                      ),
                      borderRadius: BorderRadius.circular(20),
                      boxShadow: [
                        BoxShadow(
                          color: const Color(0xFF2196F3).withOpacity(0.3),
                          blurRadius: 15,
                          offset: const Offset(0, 8),
                        ),
                      ],
                    ),
                    child: ElevatedButton(
                      onPressed: () {
                         Navigator.pop(context);
                         _launchExternalUrl(url);
                      },
                      style: ElevatedButton.styleFrom(
                        backgroundColor: Colors.transparent,
                        foregroundColor: Colors.white,
                        padding: const EdgeInsets.symmetric(vertical: 20),
                        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
                        elevation: 0,
                        shadowColor: Colors.transparent,
                      ),
                      child: Row(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          const Icon(Icons.open_in_browser_rounded, size: 24),
                          const SizedBox(width: 12),
                          Text(
                            openBtn, 
                            style: lang.getTextStyle(fontSize: 18, fontWeight: FontWeight.bold),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ],
            ),
          ),
        );
      },
    );
  }

