          children: [
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                gradient: const LinearGradient(
                  begin: Alignment.topLeft,
                  end: Alignment.bottomRight,
                  colors: [Color(0xFFEF4444), Color(0xFFB91C1C)],
                ),
                shape: BoxShape.circle,
                boxShadow: [
                  BoxShadow(
                    color: const Color(0xFFB91C1C).withOpacity(0.4),
                    blurRadius: 10,
                    offset: const Offset(0, 4),
                  )
                ],
              ),
              child: const Icon(Icons.favorite_rounded, color: Colors.white, size: 24),
            ),
            const SizedBox(height: 12),
            Text(
               cardTitle,
               style: lang.getTextStyle(fontSize: 14, fontWeight: FontWeight.bold, color: isDark ? Colors.white : const Color(0xFF7F1D1D)),
               textAlign: TextAlign.center,
            ),
          ],
        ),
      ),
    );
  }


  Widget _buildDrAltaafiCard(LanguageService lang, bool isDark) {
    String cardTitle;
    switch (lang.currentLanguage) {
      case AppLanguage.arabic: cardTitle = 'دكتور رفيق التعافي'; break;
      case AppLanguage.kurdish: cardTitle = 'دکتۆری ڕەفیقی تعافی'; break;
      case AppLanguage.english: cardTitle = 'Dr. Rafiq Al-Taafi'; break;
    }

    return GestureDetector(
      onTap: () {
        Navigator.push(
          context,
          MaterialPageRoute(
            builder: (context) => WebViewScreen(
              title: cardTitle,
